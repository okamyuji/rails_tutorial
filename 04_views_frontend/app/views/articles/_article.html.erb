<div class="article">
  <h2><%= article.title %></h2>
  <p class="author">by <%= article.user.name %></p>
  <div class="content">
    <%= article.content %>
  </div>
  <div class="meta">
    <span><%= article.created_at.strftime('%Y-%m-%d') %></span>
    <span><%= article.comments.count %> comments</span>
  </div>
</div>
