<%# app/views/articles/_article.html.erb %>
<%# 記事パーシャル - 記事の表示を再利用可能にします %>
<%# ローカル変数: article（必須） %>

<%# 
  使用例:
  <%= render @articles %>
  <%= render partial: "articles/article", collection: @articles %>
  <%= render "articles/article", article: @article %>
%>

<article class="article-card" id="<%= dom_id(article) %>">
  <%# 記事ヘッダー %>
  <header class="article-header">
    <h2 class="article-title">
      <%= link_to article.title, article_path(article), class: "article-link" %>
    </h2>
    
    <div class="article-meta">
      <%# 著者情報 %>
      <span class="article-author">
        <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
        by <%= article.user.name %>
      </span>
      
      <%# 投稿日時 %>
      <span class="article-date">
        <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <time datetime="<%= article.created_at.iso8601 %>">
          <%= article.created_at.strftime('%Y-%m-%d %H:%M') %>
        </time>
      </span>
      
      <%# 公開ステータス %>
      <% if article.published? %>
        <span class="badge badge-success">
          <svg class="badge-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          Published
        </span>
      <% else %>
        <span class="badge badge-secondary">
          <svg class="badge-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                  d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
          </svg>
          Draft
        </span>
      <% end %>
    </div>
  </header>
  
  <%# 記事本文（要約） %>
  <div class="article-content">
    <%= truncate(article.content, length: 200, omission: '...') %>
  </div>
  
  <%# 記事フッター %>
  <footer class="article-footer">
    <%# コメント数 %>
    <span class="article-comments">
      <svg class="meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
              d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
      </svg>
      <%= pluralize(article.comments.count, 'comment') %>
    </span>
    
    <%# アクションボタン %>
    <div class="article-actions">
      <%= link_to article_path(article), class: 'btn btn-primary btn-sm' do %>
        Read More
        <svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
        </svg>
      <% end %>
      
      <%= link_to edit_article_path(article), class: 'btn btn-secondary btn-sm' do %>
        <svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
        Edit
      <% end %>
      
      <%= button_to article_path(article), 
                    method: :delete, 
                    form: { data: { turbo_confirm: 'Are you sure you want to delete this article?' } },
                    class: 'btn btn-danger btn-sm' do %>
        <svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
        Delete
      <% end %>
    </div>
  </footer>
</article>

