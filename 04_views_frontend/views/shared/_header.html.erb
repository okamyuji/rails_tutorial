<%# app/views/shared/_header.html.erb %>
<%# サイト共通のヘッダーパーシャル %>
<%# ナビゲーション、ロゴ、ユーザーメニューを含みます %>

<header class="site-header" role="banner">
  <div class="container header-container">
    <%# ロゴ %>
    <div class="header-logo">
      <%= link_to root_path, class: "logo-link" do %>
        <span class="logo-text">My Blog</span>
      <% end %>
    </div>

    <%# メインナビゲーション %>
    <nav class="main-nav" role="navigation" aria-label="Main navigation">
      <ul class="nav-list">
        <li class="nav-item">
          <%= link_to "Home", root_path, class: "nav-link #{active_class(root_path)}" %>
        </li>
        <li class="nav-item">
          <%= link_to "Articles", articles_path, class: "nav-link #{active_class(articles_path)}" %>
        </li>
        <li class="nav-item">
          <%= link_to "About", about_path, class: "nav-link #{active_class(about_path)}" %>
        </li>
        <li class="nav-item">
          <%= link_to "Contact", contact_path, class: "nav-link #{active_class(contact_path)}" %>
        </li>
      </ul>
    </nav>

    <%# ユーザーメニュー（Stimulusドロップダウン使用） %>
    <div class="user-menu" data-controller="dropdown">
      <% if current_user %>
        <%# ログイン済みユーザー %>
        <button type="button"
                class="user-menu-button"
                data-action="click->dropdown#toggle"
                aria-expanded="false"
                aria-haspopup="true">
          <span class="user-avatar">
            <%= current_user.name.first.upcase %>
          </span>
          <span class="user-name"><%= current_user.name %></span>
          <svg class="dropdown-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <div class="dropdown-menu hidden" data-dropdown-target="menu">
          <%= link_to "Profile", profile_path, class: "dropdown-item" %>
          <%= link_to "Settings", settings_path, class: "dropdown-item" %>
          <% if current_user.admin? %>
            <%= link_to "Admin", admin_path, class: "dropdown-item" %>
          <% end %>
          <hr class="dropdown-divider">
          <%= button_to "Sign Out", logout_path, method: :delete, class: "dropdown-item dropdown-item-danger" %>
        </div>
      <% else %>
        <%# 未ログインユーザー %>
        <div class="auth-buttons">
          <%= link_to "Sign In", login_path, class: "btn btn-outline" %>
          <%= link_to "Sign Up", signup_path, class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>

    <%# モバイルメニューボタン %>
    <button type="button"
            class="mobile-menu-button"
            data-action="click->mobile-menu#toggle"
            aria-label="Toggle navigation menu">
      <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
</header>
