<%# app/views/comments/_comment.html.erb %>
<%# コメントパーシャル %>
<%# ローカル変数: comment（必須） %>

<div class="comment" id="<%= dom_id(comment) %>">
  <div class="comment-header">
    <%# ユーザーアバター %>
    <div class="comment-avatar">
      <%= comment.user.name.first.upcase %>
    </div>
    
    <%# ユーザー情報 %>
    <div class="comment-meta">
      <span class="comment-author"><%= comment.user.name %></span>
      <time class="comment-date" datetime="<%= comment.created_at.iso8601 %>">
        <%= time_ago_in_words(comment.created_at) %> ago
      </time>
    </div>
  </div>
  
  <%# コメント本文 %>
  <div class="comment-content">
    <%= simple_format(comment.content) %>
  </div>
  
  <%# コメントアクション %>
  <div class="comment-actions">
    <% if current_user == comment.user || current_user&.admin? %>
      <%= link_to edit_article_comment_path(comment.article, comment), 
                  class: "comment-action",
                  data: { turbo_frame: "comment_#{comment.id}" } do %>
        <svg class="action-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
        Edit
      <% end %>
      
      <%= button_to article_comment_path(comment.article, comment),
                    method: :delete,
                    form: { data: { turbo_confirm: "Delete this comment?" } },
                    class: "comment-action comment-action-danger" do %>
        <svg class="action-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
        Delete
      <% end %>
    <% end %>
  </div>
</div>

