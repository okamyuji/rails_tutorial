<%# app/views/admin/_sidebar.html.erb %>
<%# 管理画面のサイドバーパーシャル %>

<nav class="admin-nav">
  <%# ダッシュボード %>
  <div class="nav-section">
    <h4 class="nav-section-title">Dashboard</h4>
    <ul class="nav-list">
      <li class="nav-item">
        <%= link_to admin_path, class: "nav-link #{active_class(admin_path)}" do %>
          <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                  d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
          </svg>
          Overview
        <% end %>
      </li>
      <li class="nav-item">
        <%= link_to admin_analytics_path, class: "nav-link #{active_class(admin_analytics_path)}" do %>
          <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                  d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
          </svg>
          Analytics
        <% end %>
      </li>
    </ul>
  </div>
  
  <%# コンテンツ管理 %>
  <div class="nav-section">
    <h4 class="nav-section-title">Content</h4>
    <ul class="nav-list">
      <li class="nav-item">
        <%= link_to admin_articles_path, class: "nav-link #{active_class(admin_articles_path)}" do %>
          <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                  d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          Articles
          <span class="nav-badge"><%= Article.count %></span>
        <% end %>
      </li>
      <li class="nav-item">
        <%= link_to admin_comments_path, class: "nav-link #{active_class(admin_comments_path)}" do %>
          <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                  d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
          Comments
          <span class="nav-badge"><%= Comment.count %></span>
        <% end %>
      </li>
    </ul>
  </div>
  
  <%# ユーザー管理 %>
  <div class="nav-section">
    <h4 class="nav-section-title">Users</h4>
    <ul class="nav-list">
      <li class="nav-item">
        <%= link_to admin_users_path, class: "nav-link #{active_class(admin_users_path)}" do %>
          <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                  d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
          All Users
          <span class="nav-badge"><%= User.count %></span>
        <% end %>
      </li>
    </ul>
  </div>
  
  <%# 設定 %>
  <div class="nav-section">
    <h4 class="nav-section-title">Settings</h4>
    <ul class="nav-list">
      <li class="nav-item">
        <%= link_to admin_settings_path, class: "nav-link #{active_class(admin_settings_path)}" do %>
          <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                  d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          Site Settings
        <% end %>
      </li>
    </ul>
  </div>
</nav>

