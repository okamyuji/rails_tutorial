<%# app/views/devise/shared/_links.html.erb %>
<%# 認証関連の共通リンク %>

<nav class="auth-links">
  <%# ログインリンク %>
  <% if controller_name != 'sessions' %>
    <div class="auth-link-item">
      <%= link_to "Sign in", new_session_path(resource_name), class: "auth-link" %>
    </div>
  <% end %>

  <%# 登録リンク %>
  <% if devise_mapping.registerable? && controller_name != 'registrations' %>
    <div class="auth-link-item">
      <%= link_to "Sign up", new_registration_path(resource_name), class: "auth-link" %>
    </div>
  <% end %>

  <%# パスワードリセットリンク %>
  <% if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <div class="auth-link-item">
      <%= link_to "Forgot your password?", new_password_path(resource_name), class: "auth-link" %>
    </div>
  <% end %>

  <%# 確認メール再送信リンク %>
  <% if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <div class="auth-link-item">
      <%= link_to "Didn't receive confirmation instructions?", new_confirmation_path(resource_name), class: "auth-link" %>
    </div>
  <% end %>

  <%# ロック解除リンク %>
  <% if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <div class="auth-link-item">
      <%= link_to "Didn't receive unlock instructions?", new_unlock_path(resource_name), class: "auth-link" %>
    </div>
  <% end %>

  <%# OmniAuthリンク %>
  <% if devise_mapping.omniauthable? %>
    <div class="auth-social-links">
      <% resource_class.omniauth_providers.each do |provider| %>
        <div class="auth-link-item">
          <%= button_to omniauth_authorize_path(resource_name, provider),
                        method: :post,
                        data: { turbo: false },
                        class: "btn btn-social btn-#{provider}" do %>
            Sign in with <%= OmniAuth::Utils.camelize(provider) %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</nav>
