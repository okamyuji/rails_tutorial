<%# app/views/devise/passwords/edit.html.erb %>
<%# パスワード変更フォーム %>

<div class="auth-container">
  <div class="auth-card">
    <header class="auth-header">
      <h1 class="auth-title">Reset Password</h1>
      <p class="auth-subtitle">
        Enter your new password below.
      </p>
    </header>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "auth-form" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <%= f.hidden_field :reset_password_token %>

      <div class="form-group">
        <%= f.label :password, "New password", class: "form-label" %>
        <%= f.password_field :password,
                             autofocus: true,
                             autocomplete: "new-password",
                             class: "form-control",
                             placeholder: "Enter new password" %>
        <% if @minimum_password_length %>
          <small class="form-text text-muted">
            <%= @minimum_password_length %> characters minimum
          </small>
        <% end %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, "Confirm new password", class: "form-label" %>
        <%= f.password_field :password_confirmation,
                             autocomplete: "new-password",
                             class: "form-control",
                             placeholder: "Confirm new password" %>
      </div>

      <div class="form-actions">
        <%= f.submit "Change Password", class: "btn btn-primary btn-block" %>
      </div>
    <% end %>

    <footer class="auth-footer">
      <%= link_to "Back to sign in", new_session_path(resource_name), class: "auth-link" %>
    </footer>
  </div>
</div>

