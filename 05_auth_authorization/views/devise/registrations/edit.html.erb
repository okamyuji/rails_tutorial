<%# app/views/devise/registrations/edit.html.erb %>
<%# アカウント編集フォーム %>

<div class="auth-container">
  <div class="auth-card auth-card-wide">
    <header class="auth-header">
      <h1 class="auth-title">Account Settings</h1>
      <p class="auth-subtitle">Update your account information</p>
    </header>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "auth-form" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <%# プロフィール情報 %>
      <fieldset class="form-fieldset">
        <legend class="form-legend">Profile Information</legend>

        <div class="form-group">
          <%= f.label :name, class: "form-label" %>
          <%= f.text_field :name,
                           autofocus: true,
                           autocomplete: "name",
                           class: "form-control" %>
        </div>

        <div class="form-group">
          <%= f.label :email, class: "form-label" %>
          <%= f.email_field :email,
                            autocomplete: "email",
                            class: "form-control" %>
          <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
            <small class="form-text text-warning">
              Currently waiting confirmation for: <%= resource.unconfirmed_email %>
            </small>
          <% end %>
        </div>
      </fieldset>

      <%# パスワード変更 %>
      <fieldset class="form-fieldset">
        <legend class="form-legend">Change Password</legend>
        <p class="form-text text-muted">Leave blank if you don't want to change it</p>

        <div class="form-group">
          <%= f.label :password, "New password", class: "form-label" %>
          <%= f.password_field :password,
                               autocomplete: "new-password",
                               class: "form-control",
                               placeholder: "New password" %>
          <% if @minimum_password_length %>
            <small class="form-text text-muted">
              <%= @minimum_password_length %> characters minimum
            </small>
          <% end %>
        </div>

        <div class="form-group">
          <%= f.label :password_confirmation, "Confirm new password", class: "form-label" %>
          <%= f.password_field :password_confirmation,
                               autocomplete: "new-password",
                               class: "form-control",
                               placeholder: "Confirm new password" %>
        </div>
      </fieldset>

      <%# 現在のパスワード確認 %>
      <fieldset class="form-fieldset">
        <legend class="form-legend">Confirm Changes</legend>

        <div class="form-group">
          <%= f.label :current_password, class: "form-label" %>
          <%= f.password_field :current_password,
                               autocomplete: "current-password",
                               class: "form-control",
                               placeholder: "Enter current password to confirm changes" %>
          <small class="form-text text-muted">
            We need your current password to confirm your changes
          </small>
        </div>
      </fieldset>

      <div class="form-actions">
        <%= f.submit "Update Account", class: "btn btn-primary" %>
        <%= link_to "Cancel", root_path, class: "btn btn-outline" %>
      </div>
    <% end %>

    <%# アカウント削除 %>
    <hr class="auth-divider-line">

    <div class="danger-zone">
      <h3 class="danger-zone-title">Danger Zone</h3>
      <p class="danger-zone-text">
        Once you delete your account, there is no going back. Please be certain.
      </p>
      <%= button_to "Delete my account",
                    registration_path(resource_name),
                    data: { turbo_confirm: "Are you sure you want to delete your account? This action cannot be undone." },
                    method: :delete,
                    class: "btn btn-danger" %>
    </div>

    <footer class="auth-footer">
      <%= link_to "Back to home", root_path, class: "auth-link" %>
    </footer>
  </div>
</div>
