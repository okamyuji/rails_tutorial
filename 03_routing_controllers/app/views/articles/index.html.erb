<h1>記事一覧</h1>

<%= link_to "新規作成", new_article_path %>

<% @articles.each do |article| %>
  <div>
    <h2><%= link_to article.title, article_path(article) %></h2>
    <p><%= truncate(article.content, length: 100) %></p>
    <small>作成日: <%= article.created_at.strftime("%Y-%m-%d %H:%M") %></small>
  </div>
<% end %>
