<%= form_with(model: article) do |f| %>
  <% if article.errors.any? %>
    <div style="padding: 0.75rem; background: #f8d7da; border: 1px solid #f5c6cb; border-radius: 4px; color: #721c24; margin-bottom: 1rem;">
      <h3><%= pluralize(article.errors.count, "error") %> prohibited this article from being saved:</h3>
      <ul>
        <% article.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div style="margin-bottom: 0.75rem;">
    <%= f.label :title, "タイトル" %><br>
    <%= f.text_field :title, style: "width: 100%;" %>
  </div>

  <div style="margin-bottom: 0.75rem;">
    <%= f.label :content, "本文" %><br>
    <%= f.text_area :content, rows: 10, style: "width: 100%;" %>
  </div>

  <div style="margin-bottom: 0.75rem;">
    <%= f.label :user_id, "ユーザーID" %><br>
    <%= f.number_field :user_id %>
  </div>

  <div style="margin-bottom: 0.75rem;">
    <%= f.check_box :published %>
    <%= f.label :published, "公開する" %>
  </div>

  <%= f.submit style: "padding: 0.5rem 1rem;" %>
<% end %>
